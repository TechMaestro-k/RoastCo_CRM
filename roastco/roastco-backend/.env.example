# ── CRM service (cmd/crm) ────────────────────────────────────────────────
# Postgres connection string.
# Supabase: prefer the SESSION POOLER string (…pooler.supabase.com:5432) — the
# direct host (db.<ref>.supabase.co) is IPv6-only and hangs on IPv4 networks.
# Never the transaction pooler (6543): prepared statements break there.
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Shared secret for BOTH directions of the channel loop. Generate one:
#   openssl rand -hex 24
# Must be identical on the crm and channel services.
CHANNEL_SHARED_SECRET=change-me

# AI: "grok" (live LLM) or "mock" (deterministic offline planner).
# Default: grok when XAI_API_KEY is set, otherwise mock.
# The provider is auto-detected from the key prefix:
#   xai-…  → xAI Grok   (model e.g. grok-4.1-fast)
#   gsk_…  → Groq        (model e.g. llama-3.3-70b-versatile)
# Verify both this and the DB in 5s:  ./scripts/check_live.sh
AI_MODE=grok
XAI_API_KEY=
GROK_MODEL=
# XAI_BASE_URL=https://api.x.ai/v1

# Where the channel service lives, and the public URL of OUR receipts endpoint
# (the channel posts callbacks there — it must be reachable from the channel).
CHANNEL_URL=http://localhost:8081
CALLBACK_URL=http://localhost:8080/api/receipts

# CORS origin of the deployed frontend ("*" for local dev).
FRONTEND_ORIGIN=*

# Tuning (sensible defaults; shown here for visibility)
# PORT=8080
# WORKER_COUNT=12
# DISPATCH_BATCH=20
# DISPATCH_MAX_ATTEMPTS=5
# DISPATCH_BASE_BACKOFF_SEC=5
# DB_MAX_CONNS=25
# ATTRIBUTION_WINDOW_DAYS=7

# ── Channel service (cmd/channel) ───────────────────────────────────────
# Needs only: PORT, CHANNEL_SHARED_SECRET, and the chaos knobs:
# CHANNEL_TRANSIENT_RATE=0.03   # /send answers 503 (exercises CRM retries)
# CHANNEL_FAIL_RATE=0.06        # lifecycle ends in 'failed'
# CHANNEL_DUP_RATE=0.12         # callbacks deliberately duplicated
# CHANNEL_MIN_DELAY_MS=800
# CHANNEL_MAX_DELAY_MS=6000

# ── Seeder (cmd/seed) ────────────────────────────────────────────────────
# SEED_API_URL=http://localhost:8080
